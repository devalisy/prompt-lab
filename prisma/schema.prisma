generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  image     String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prompts      Prompt[]
  savedPrompts SavedPrompt[]
  likes        Like[]
  comments     Comment[]
  accounts     Account[]
  sessions     Session[]
  skills       Skill[]
  skillLikes   SkillLike[]
  savedSkills  SavedSkill[]
  eventLogs    EventLog[]
  companiesOwned Company[]
  companyMembers CompanyMember[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id          String   @id
  name        String
  description String
  color       String
  icon        String
  promptCount Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  prompts Prompt[]
  skills  Skill[]
}

model Prompt {
  id          String   @id @default(cuid())
  title       String
  content     String
  tips        String   @default("[]")
  description String?
  level       String   @default("intermediate")
  tags        String   @default("[]")
  usageCount  Int      @default(0)
  isPublic    Boolean  @default(false)
  categoryId  String
  authorId    String?
  companyId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   category    Category      @relation(fields: [categoryId], references: [id])
   author      User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
   company     Company?      @relation(fields: [companyId], references: [id])
  savedBy     SavedPrompt[]
  likes       Like[]
  comments    Comment[]
}

model SavedPrompt {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  companyId String?
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@unique([userId, promptId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  promptId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([userId, promptId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  promptId  String
  skillId   String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prompt Prompt? @relation(fields: [promptId], references: [id], onDelete: Cascade)
  skill  Skill?  @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

model Skill {
  id           String   @id @default(cuid())
  title        String
  description  String
  systemPrompt String
  variables    String   @default("[]")
  exampleInput String?
  tags         String   @default("[]")
  usageCount   Int      @default(0)
  isPublic     Boolean  @default(false)
  categoryId   String
  authorId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
  author   User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  likes    SkillLike[]
  savedBy  SavedSkill[]
  comments Comment[]
}

model SkillLike {
  id        String   @id @default(cuid())
  userId    String
  skillId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model SavedSkill {
  id        String   @id @default(cuid())
  userId    String
  skillId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

model EventLog {
  id        String   @id @default(cuid())
  type      String
  message   String
  userId    String?
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([createdAt])
}

enum CompanyRole {
  OWNER
  ADMIN
  MEMBER
}

model Company {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  logo        String?
  defaults    Json?
  ownerId     String?
  createdAt   DateTime       @default(now())

  owner   User?           @relation(fields: [ownerId], references: [id])
  members CompanyMember[]
  prompts Prompt[]
  savedPrompts SavedPrompt[]
}

model CompanyMember {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole @default(MEMBER)
  createdAt DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}
